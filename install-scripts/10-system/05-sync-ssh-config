#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/../lib/print"

pass_cli="$HOME/.local/bin/pass-cli"
ssh_dir="$HOME/.ssh"
config_file="$ssh_dir/config"
agent_sock="$ssh_dir/proton-pass-agent.sock"
keys_dir="$ssh_dir/proton-keys"
block_begin="# >>> proton-pass (managed by dotfiles) >>>"
block_end="# <<< proton-pass (managed by dotfiles) <<<"

slugify() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'
}

# Recreate the managed key directory
rm -rf "$keys_dir"
mkdir -p "$keys_dir"
chmod 700 "$keys_dir"

mapfile -t vaults < <("$pass_cli" vault list --output json 2>/dev/null | jq -r '.vaults[].name')
if [[ ${#vaults[@]} -eq 0 ]]; then
    print_error "no vaults returned by pass-cli (is the Proton Pass session unlocked?)"
    exit 1
fi

block=$block_begin$'\n'
count=0

for vault in "${vaults[@]}"; do
    items_json=$("$pass_cli" item list "$vault" --filter-type ssh-key --output json 2>/dev/null || true)
    [[ -n $items_json ]] || continue

    while IFS=$'\t' read -r share_id item_id; do
        [[ -n $item_id ]] || continue

        item_json=$("$pass_cli" item view --share-id "$share_id" --item-id "$item_id" --output json 2>/dev/null || true)
        [[ -n $item_json ]] || continue

        IFS=$'\t' read -r title host user pubkey < <(
            printf '%s' "$item_json" | jq -r '
                .item.content as $c
                | [ $c.title,
                    ($c.extra_fields[]? | select(.name=="Host")     | .content.Text) // "",
                    ($c.extra_fields[]? | select(.name=="Username") | .content.Text) // "",
                    ($c.content.SshKey.public_key) // ""
                  ] | @tsv'
        )

        if [[ -z $host ]]; then
            print_warning "skipping '$title': no Host field set in Proton Pass"
            continue
        fi
        if [[ -z $pubkey ]]; then
            print_warning "skipping '$title': no public key in item"
            continue
        fi

        slug=$(slugify "$title")
        pub_file="$keys_dir/$slug.pub"
        printf '%s\n' "$pubkey" >"$pub_file"
        chmod 644 "$pub_file"

        block+="Host $host"$'\n'
        [[ -n $user ]] && block+="    User $user"$'\n'
        block+="    IdentitiesOnly yes"$'\n'
        block+="    IdentityFile $pub_file"$'\n'
        block+="    IdentityAgent $agent_sock"$'\n'
        block+=$'\n'

        print_step "$host -> $slug.pub"
        count=$((count + 1))
    done < <(printf '%s' "$items_json" | jq -r '(.items // .)[] | [.share_id, .id] | @tsv')
done

block+=$block_end

tmp=$(mktemp)

if [[ -f $config_file ]]; then
    awk -v b="$block_begin" -v e="$block_end" '
        $0 == b { skip = 1 }
        skip && $0 == e { skip = 0; next }
        !skip { print }
    ' "$config_file" >"$tmp"

    sed -i -e :a -e '/^\n*$/{$d;N;ba}' "$tmp"

    [[ -s $tmp ]] && printf '\n' >>"$tmp"
fi

printf '%s\n' "$block" >>"$tmp"

mv "$tmp" "$config_file"
chmod 600 "$config_file"

print_step Done
