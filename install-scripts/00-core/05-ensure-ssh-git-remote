#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/../lib/print"

repo_root="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel)"
remote_name=origin

print_step "Switching dotfiles Git remote to SSH"

if ! remote_url="$(git -C "$repo_root" remote get-url "$remote_name" 2>/dev/null)"; then
    print_step "No $remote_name Git remote found, not updating"
    exit 0
fi

case "$remote_url" in
    https://github.com/*)
        if ! gum confirm "Have you added this machine's SSH key to GitHub?"; then
            print_step "GitHub SSH key not confirmed, not updating $remote_name remote"
            exit 0
        fi

        ssh_url="git@github.com:${remote_url#https://github.com/}"

        git -C "$repo_root" remote set-url "$remote_name" "$ssh_url"
        print_step "Updated $remote_name remote to $ssh_url"
        ;;
    git@github.com:*|ssh://git@github.com/*)
        print_step "$remote_name remote already uses GitHub SSH"
        ;;
    *)
        print_step "$remote_name remote is not a GitHub HTTPS URL, not updating"
        ;;
esac

print_step Done
