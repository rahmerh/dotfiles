#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/../lib/print"

runcat_dir="$HOME/.local/share/waybar/runcat-text"
runcat_repo="https://github.com/bzglve/runcat-text.git"

if [[ -d "$runcat_dir/.git" ]]; then
    print_step "Updating runcat-text"
    git -C "$runcat_dir" pull --ff-only
elif [[ -e "$runcat_dir" ]]; then
    print_error "$runcat_dir exists but is not a git repository"
    exit 1
else
    print_step "Installing runcat-text"
    mkdir -p "$(dirname "$runcat_dir")"
    git clone "$runcat_repo" "$runcat_dir"
fi

chmod +x "$runcat_dir/main.py"
python -m venv "$runcat_dir/.venv"
"$runcat_dir/.venv/bin/python" -m pip install --upgrade pip
"$runcat_dir/.venv/bin/python" -m pip install -r "$runcat_dir/requirements.txt"

install -Dm644 "$runcat_dir/runcat.ttf" "$HOME/.local/share/fonts/runcat.ttf"
fc-cache -f "$HOME/.local/share/fonts"

print_step Done
