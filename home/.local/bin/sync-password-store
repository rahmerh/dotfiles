#!/usr/bin/env bash

vaults_json=$(pass-cli vault list --output json) || exit 1
mapfile -t vaults < <(jq -r '.vaults[].name' <<<"$vaults_json")

entries=()
for vault in "${vaults[@]}"; do
    vault_entries_json=$(
        pass-cli item list "$vault" --output json --filter-type login
    ) || exit 1

    mapfile -t vault_entries < <(jq -c '.items[]' <<<"$vault_entries_json")
    entries+=("${vault_entries[@]}")
done

cache_dir="$HOME/.cache/password-store"
cache_file="$cache_dir/entries.json"

mkdir -p "$cache_dir"
chmod 700 "$cache_dir"

printf '%s\n' "${entries[@]}" | jq -s . >"$cache_file"
chmod 600 "$cache_file"
