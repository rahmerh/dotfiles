#!/usr/bin/env bash

ls() {
    if [[ -t 1 ]]; then
        eza -a1 --icons=always --group-directories-first --color=always "$@" | sed 's/^/  /'
        return "${PIPESTATUS[0]}"
    fi

    eza -a1 --icons=always --group-directories-first "$@"
}

reload() {
    exec bash
}

ipi() {
    curl -sS ipinfo.io | jq
}

calc() {
    echo "scale=10; $*" | bc -l
}

handmirror() {
    local device="${1:-/dev/video0}"
    local fps="${HANDMIRROR_FPS:-60}"
    local size="${HANDMIRROR_SIZE:-1280x720}"

    if ! command -v ffplay >/dev/null 2>&1; then
        echo "handmirror requires ffplay from the ffmpeg package" >&2
        return 127
    fi

    ffplay \
        -hide_banner \
        -loglevel warning \
        -fflags nobuffer \
        -flags low_delay \
        -framedrop \
        -sync ext \
        -an \
        -f v4l2 \
        -framerate "$fps" \
        -video_size "$size" \
        -i "$device" \
        -vf hflip
}

why() {
    local code=$?
    local red=$'\033[31m'
    local reset=$'\033[0m'
    local last_cmd max_len shown_cmd signal

    if (( code == 0 )); then
        echo "Why what? Nothing went wrong."
        return 0
    fi

    printf '%s%s%s' "$red" "$code" "$reset"

    case "$code" in
        1)
            echo " – general error (e.g. test failed)"
            ;;
        2)
            echo " – misuse of shell builtins"
            ;;
        126)
            echo " – permission denied or not executable"
            ;;
        127)
            echo " – command not found"
            ;;
        128)
            echo " – invalid exit value or repo error"
            ;;
        130)
            echo " – terminated by Ctrl-C (SIGINT)"
            ;;
        139)
            echo " – segmentation fault"
            ;;
        *)
            if (( code >= 129 && code <= 255 )); then
                signal=$((code - 128))

                case "$signal" in
                    9)
                        echo " – killed (SIGKILL)"
                        ;;
                    15)
                        echo " – terminated (SIGTERM)"
                        ;;
                    *)
                        echo " – exited via signal $signal"
                        ;;
                esac
            else
                echo " – unknown or uncommon error"
            fi
            ;;
    esac

    last_cmd=$(fc -ln -2 -2 2>/dev/null)

    max_len=50
    if (( ${#last_cmd} > max_len )); then
        shown_cmd="${last_cmd:0:max_len}... [truncated]"
    else
        shown_cmd="$last_cmd"
    fi

    printf '↳ "%s"\n' "$shown_cmd"
}

alias lo='eza -lah --icons=always --group-directories-first --git --total-size'
alias cat='bat'
alias lg='lazygit'
alias v='nvim'
