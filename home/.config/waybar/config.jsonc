{
    "include": [
        "~/.config/waybar/modules/clock.jsonc",
        "~/.config/waybar/modules/date.jsonc",
        "~/.config/waybar/modules/hardware.jsonc",
        "~/.config/waybar/modules/tray.jsonc"
    ],
    "layer": "top",
    "position": "top",
    "modules-right": [
        "tray",
        "group/hardware",
        "network",
        "custom/date",
        "custom/time"
    ]
}
