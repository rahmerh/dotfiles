#!/usr/bin/env bash
set -o pipefail

BACKUP_DIR="/var/lib/backup-system"
CONF_FILE="$BACKUP_DIR/config"
LOG_FILE="$BACKUP_DIR/log"
LAST_SUCCESS_FILE="$BACKUP_DIR/last-success"
STATUS_FILE="$BACKUP_DIR/status"

# Example /var/lib/backup-system/config:
# DESTINATION="backup-host:/srv/backups/system"
# BACKUP_DIRS="/home/user/"
# SSH_KEY_FILE="/root/.ssh/backup-system"
# Optional:
# EXCLUDES="/.cache:/.local/share/Trash"

install --directory --owner=root --group=root --mode=0755 "$BACKUP_DIR"
: >"$LOG_FILE"
chmod 0644 "$LOG_FILE"

log() {
    printf '%s\n' "$*" | tee -a "$LOG_FILE"
}

write_status() {
    printf '%s\t%s\t%s\n' "$(date --iso-8601=seconds)" "$1" "$2" >"$STATUS_FILE"
    chmod 0644 "$STATUS_FILE"
}

fail() {
    log "$1"
    write_status error "$1"
    exit 1
}

trap 'fail "System backup interrupted."' INT TERM

today="$(date +%F)"
if [[ -r "$LAST_SUCCESS_FILE" ]] && [[ "$(cat "$LAST_SUCCESS_FILE")" == "$today" ]]; then
    log "System backup already completed today."
    exit 0
fi

[[ -f "$CONF_FILE" ]] || fail "Config file not found: $CONF_FILE"

# shellcheck disable=SC1090
source "$CONF_FILE"

IFS=":" read -r -a sources <<<"$BACKUP_DIRS"

rsync_args=(
    -a
    --delete
    --progress
    --no-group
    --no-owner
    -e "ssh -i $SSH_KEY_FILE -o IdentitiesOnly=yes"
)

if [[ -n "${EXCLUDES:-}" ]]; then
    IFS=":" read -r -a excludes <<<"$EXCLUDES"
    for exclude in "${excludes[@]}"; do
        rsync_args+=(--exclude="$exclude")
    done
fi

log "Starting system backup to $DESTINATION"
log "Sources: ${sources[*]}"
log "Log: $LOG_FILE"
write_status running "System backup started."

if rsync "${rsync_args[@]}" "${sources[@]}" "$DESTINATION" 2>&1 | tee -a "$LOG_FILE"; then
    printf '%s\n' "$today" >"$LAST_SUCCESS_FILE"
    chmod 0644 "$LAST_SUCCESS_FILE"
    log "System backup completed."
    write_status completed "System backup completed."
else
    fail "System backup failed."
fi
